# Backend API origin. If unset, the app uses the default in `src/config/api.ts` (Railway production).
# Local Express example:
# VITE_API_URL=http://127.0.0.1:5000
VITE_API_URL=https://server-production-1c6f5.up.railway.app

# Optional: set VITE_* in this file OR in the repo root .env (vite.config merges both; client wins on conflict).

# About page video: defaults to public/assets/videos/company-promo.mp4 then public/videos/, or first file from GET /api/media/first-video
# VITE_ABOUT_VIDEO_URL=https://example.com/clip.mp4
# VITE_ABOUT_VIDEO_POSTER=/assets/videos/poster.jpg
# VITE_ABOUT_VIDEO_AUTOPLAY=1

# VITE_GOOGLE_MAPS_EMBED_URL=
# VITE_GOOGLE_MAPS_LINK=
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_WHATSAPP_NUMBER=
# VITE_MESSENGER_PAGE=
