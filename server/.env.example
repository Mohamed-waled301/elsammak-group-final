PORT=5000

MONGO_URI=mongodb://127.0.0.1:27017/elsammak



# Required for login and tokens (min ~16 chars).

# JWT_SECRET=change-this-to-a-long-random-secret



# DEBUG_LOGIN=1 logs email and password lengths (and hash prefixes) to the server console — development only.

# DEBUG_LOGIN=1



# First administrator is created once via POST /api/auth/bootstrap-admin from the auth page (no ADMIN_EMAIL / ADMIN_PASSWORD).



# To remove all admins and run bootstrap again (from server/):

# node scripts/purgeAdmins.js



# Password-reset OTP is only sent if a User with this email exists.

# Optional: node scripts/seedUser.js user@example.com



# Put Gmail credentials in the MONOREPO ROOT .env (../.env) as EMAIL_USER / EMAIL_PASS

# (use a Gmail App Password, not your normal login password).

# Server loads ../.env first, then this file.



# MAIL_MIN_GAP_MS=1500

# CONTACT_TO_EMAIL=owner@example.com

# CORS_ORIGIN=https://your-production-app.com

